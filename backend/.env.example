# Copy this file to `.env` and adjust as needed.
#
# The defaults below match the services in ../docker-compose.yml, which publish
# PostgreSQL on localhost:5432 and Redis on localhost:6379. If you run Postgres
# or Redis somewhere else, change the URLs accordingly.

# Port the NestJS HTTP server listens on.
PORT=3000

# PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eventbooking

# Redis connection string (used by BullMQ).
REDIS_URL=redis://localhost:6379
